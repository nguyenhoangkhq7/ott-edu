    {
      "name": "2. Teacher - Assignment Management",
      "item": [
        {
          "name": "Create QUIZ Assignment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.id) {",
                  "    pm.collectionVariables.set(\"assignmentId\", jsonData.id);",
                  "    console.log(\"New quiz assignmentId saved: \" + jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Kiểm tra trắc nghiệm OOP Java\",\n  \"instructions\": \"Hãy trả lời các câu hỏi trắc nghiệm dưới đây. Giới hạn 2 lượt làm bài.\",\n  \"type\": \"QUIZ\",\n  \"dueDate\": \"2026-12-31T23:59:59\",\n  \"maxScore\": 10.0,\n  \"teamIds\": [{{teamId}}],\n  \"maxAttempts\": 2,\n  \"timeLimit\": 45,\n  \"questions\": [\n    {\n      \"content\": \"Java có hỗ trợ đa kế thừa lớp hay không?\",\n      \"type\": \"TRUE_FALSE\",\n      \"points\": 5.0,\n      \"displayOrder\": 1,\n      \"options\": [\n        { \"content\": \"Đúng (True)\", \"isCorrect\": false, \"displayOrder\": 1 },\n        { \"content\": \"Sai (False)\", \"isCorrect\": true, \"displayOrder\": 2 }\n      ]\n    },\n    {\n      \"content\": \"Những từ khóa hoặc chú thích nào liên quan đến tính đa hình trong Java? (Chọn tất cả các đáp án đúng)\",\n      \"type\": \"MULTI_CHOICE\",\n      \"points\": 5.0,\n      \"displayOrder\": 2,\n      \"options\": [\n        { \"content\": \"@Override\", \"isCorrect\": true, \"displayOrder\": 1 },\n        { \"content\": \"extends\", \"isCorrect\": true, \"displayOrder\": 2 },\n        { \"content\": \"implements\", \"isCorrect\": true, \"displayOrder\": 3 },\n        { \"content\": \"static\", \"isCorrect\": false, \"displayOrder\": 4 }\n      ]\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/assignments/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "assignments",
                "create"
              ]
            },
            "description": "Create a new QUIZ assignment containing sample questions. Only accessible for TEACHER role."
          },
          "response": []
        },
