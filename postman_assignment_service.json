    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Login as Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "    pm.collectionVariables.set(\"teacherToken\", jsonData.data.accessToken);",
                  "    console.log(\"Teacher Token saved to accessToken and teacherToken variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{teacherEmail}}\",\n  \"password\": \"{{teacherPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Login via core-service to obtain JWT Token for Teacher role."
          },
          "response": []
        },
        {
          "name": "Login as Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "    pm.collectionVariables.set(\"studentToken\", jsonData.data.accessToken);",
                  "    console.log(\"Student Token saved to accessToken and studentToken variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{studentPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Login via core-service to obtain JWT Token for Student role."
          },
          "response": []
        },
        {
          "name": "Switch Authorization to Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var teacherToken = pm.collectionVariables.get(\"teacherToken\");",
                  "if (teacherToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", teacherToken);",
                  "    console.log(\"Switched active auth token to Teacher Token!\");",
                  "} else {",
                  "    console.log(\"teacherToken is empty. Please login as Teacher first.\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            },
            "description": "Utility request to quickly switch authorization header to Teacher. Run Login as Teacher first."
          },
          "response": []
        },
        {
          "name": "Switch Authorization to Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var studentToken = pm.collectionVariables.get(\"studentToken\");",
                  "if (studentToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", studentToken);",
                  "    console.log(\"Switched active auth token to Student Token!\");",
                  "} else {",
                  "    console.log(\"studentToken is empty. Please login as Student first.\");",
                  "}"
                ],
                "type": "text/javascript"
