# ==============================================================================
# Complete Production Environment Variables Template (.env.prod.example)
# ==============================================================================
# Instructions:
#   1. Copy this file to your AWS EC2 remote server as `.env`
#   2. Place it in the same directory as `docker-compose.prod.yml`
#   3. Replace all placeholder values <...> with your actual credentials.
#   4. Do NOT commit the actual `.env` file containing secrets to Git!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Docker Registry Configuration
# ------------------------------------------------------------------------------
# Your Docker Hub username. Used to pull correct service images.
DOCKERHUB_USERNAME=nguyenhoangkhaq

# ------------------------------------------------------------------------------
# 2. Self-Hosted MySQL Configuration (on EC2)
# ------------------------------------------------------------------------------
# Choose a strong root password for your self-hosted MySQL container.
# The core-service and assignment-service will automatically connect using this.
MYSQL_ROOT_PASSWORD=your_strong_mysql_root_password_here

# ------------------------------------------------------------------------------
# 3. MongoDB Atlas Configuration (Managed Cloud DB)
# ------------------------------------------------------------------------------
# Your MongoDB Atlas database user credentials (created under Database Access)
MONGO_USER=atlas_db_user_here
MONGO_PASSWORD=atlas_db_password_here

# Your Mongo Atlas cluster domain (e.g., cluster0.xxxx.mongodb.net)
MONGO_CLUSTER=cluster0.xxxx.mongodb.net
MONGO_DB_NAME=chat_history_db

# ------------------------------------------------------------------------------
# 4. AWS S3 File Storage Configuration (For Avatars & Attachments)
# ------------------------------------------------------------------------------
AWS_S3_REGION=ap-southeast-1
AWS_S3_BUCKET=product-images-hau
AWS_S3_ACCESS_KEY=1234567890
AWS_S3_SECRET_KEY=1234567890
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_AVATAR_FOLDER=avatars
AWS_S3_AVATAR_MAX_FILE_SIZE_BYTES=5242880
APP_UPLOAD_MAX_FILE_SIZE=100MB
APP_UPLOAD_MAX_REQUEST_SIZE=100MB

# ------------------------------------------------------------------------------
# 5. SMTP Gmail Mail Sender (For OTP & User Registration Verification)
# ------------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=12@gmail.com
# Google App Password (not your primary Gmail password)
MAIL_PASSWORD=vsho sevz dacv jriy
MAIL_FROM=12@gmail.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000

# ------------------------------------------------------------------------------
# 6. OTP & Authentication Config
# ------------------------------------------------------------------------------
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_VERIFIED_TOKEN_EXPIRATION_MS=600000

# ------------------------------------------------------------------------------
# 7. CORS Allowed Origins & Security Cookie Settings
# ------------------------------------------------------------------------------
# Set this to your actual production domains (Frontend Vercel domain & Gateway API domain)
# Example: https://ott-edu.vercel.app,https://api.yourdomain.com
APP_CORS_ALLOWED_ORIGINS=https://1212.app,https://api.your-ec2-domain.com

APP_COOKIE_PATH=/api/core/auth
APP_COOKIE_SECURE=true
APP_COOKIE_SAMESITE=Lax

# ------------------------------------------------------------------------------
# 8. Chat & WebRTC Video Calling Configuration (Mediasoup)
# ------------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
WEB_APP_URL=https://your-vercel-frontend-domain.vercel.app

# Crucial: Set this to the public Elastic/IP address of your AWS EC2 instance.
EC2_PUBLIC_IP=your_ec2_public_ip_here

# Mediasoup WebRTC ports (Matches ports exposed in docker-compose.prod.yml)
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=your_ec2_public_ip_here
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40050
MEDIASOUP_WORKER_COUNT=1

# STUN/TURN Ice servers configured for Frontend
NEXT_PUBLIC_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
EXPO_PUBLIC_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]

# ------------------------------------------------------------------------------
# 9. AI Service Tunnel Connection (Cloudflare Tunnel to Local PC)
# ------------------------------------------------------------------------------
# Set this to the public Cloudflare Tunnel domain pointing to your local PC
AI_SERVICE_INTERNAL_URL=https://ai-api.yourdomain.com
