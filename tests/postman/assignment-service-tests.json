                "packages": {},
                "requests": {},
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.id) {",
                  "    pm.collectionVariables.set(\"assignmentId\", jsonData.id);\n    pm.collectionVariables.set(\"essayAssignmentId\", jsonData.id);",
                  "    console.log(\"New essay assignmentId saved: \" + jsonData.id);",
                  "}"
                ]
              }
            }
