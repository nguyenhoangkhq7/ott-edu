  "item": [
    {
      "name": "Send Friend Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 or 201\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "pm.test(\"Response time is less than 500ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "pm.test(\"Response body is a valid JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "pm.collectionVariables.set(\"currentFriendRequestId\", pm.response.json().id || pm.response.json()._id || (pm.response.json().data && pm.response.json().data.id) || pm.response.json().targetId || pm.response.json().requesterId);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"targetId\": \"user-123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/friend-requests/send",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
