{
  "info": {
    "_postman_id": "class-management-test-id",
    "name": "Class Management Integration Test",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.environment.set('adminToken', jsonData.data.accessToken || jsonData.data.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@otteducation.local\",\n  \"password\": \"Password@123\"\n}"
        },
        "url": "{{baseUrl}}/api/core/auth/login"
      },
      "response": []
    },
    {
      "name": "2. Create Team",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create Team Success', function () {",
              "    pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.environment.set('createdTeamId', jsonData.data.id);",
              "pm.test('Team name matches', function () {",
              "    pm.expect(jsonData.data.name).to.eql('Lớp Học Test CI');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Lớp Học Test CI\",\n  \"description\": \"Mô tả lớp học\",\n  \"joinCode\": \"CLASS_CI_TEST_\" + Date.now(),\n  \"departmentId\": 1,\n  \"isApprovalRequired\": false\n}"
        },
        "url": "{{baseUrl}}/api/core/teams"
      },
      "response": []
    },
    {
      "name": "3. Edit Team",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Edit Team Success', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.test('Team name updated', function () {",
              "    pm.expect(jsonData.data.name).to.eql('Lớp Học Test CI Updated');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Lớp Học Test CI Updated\",\n  \"description\": \"Mô tả lớp học đã sửa\",\n  \"joinCode\": \"CLASS_CI_TEST_UPDATED\",\n  \"departmentId\": 1,\n  \"isApprovalRequired\": false\n}"
        },
        "url": "{{baseUrl}}/api/core/teams/{{createdTeamId}}"
      },
      "response": []
    },
    {
      "name": "4. Get Team Members",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get Members Success', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.test('Has at least one member', function () {",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "    pm.expect(jsonData.data.length).to.be.above(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/core/teams/{{createdTeamId}}/members"
      },
      "response": []
    },
    {
      "name": "5. Delete Team",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Delete Team Success', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/core/teams/{{createdTeamId}}"
      },
      "response": []
    }
  ]
}
