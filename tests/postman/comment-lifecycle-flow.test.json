{
  "info": {
    "_postman_id": "c3d4e5f6-a7b8-9c0d-1e2f-3a4b5c6d7e90",
    "name": "Comment Lifecycle Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Add Comment",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response time is less than 500ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "pm.test(\"Response body is a valid JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "pm.collectionVariables.set(\"currentCommentId\", pm.response.json().id || pm.response.json().data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "comment",
              "value": "{\"content\": \"Hello\", \"postId\": \"post-123\"}",
              "type": "text"
            },
            {
              "key": "files",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/interact/comments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "interact",
            "comments"
          ]
        }
      },
      "response": []
    },
